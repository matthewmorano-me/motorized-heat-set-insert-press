'''
Follow-me test for motorized heat-set insert press.
  - Push DOWN on the load cell  -> stage moves DOWN
  - Pull / push UP on the load cell -> stage moves UP
  - |force| controls speed (bigger force = faster)
  - Limit switches halt motion before the next command
  - HX711 is read blockingly in the main loop (~10 Hz at gain=128)
  - Each force sample is logged to CSV

Stepper is driven by machine.Timer (no PIO, no libraries). HX711 owns PIO0 SM0.
GPIO per System Wiring Diagram 09APR2026.pdf.
'''

from machine import Pin, Timer
from hx711_pio import HX711
import time

# ---------------------------------------------------------------------------
# Pin assignments
# ---------------------------------------------------------------------------
PIN_STEP   = 0    # TB6600 PUL-  (common anode)
PIN_DIR    = 1    # TB6600 DIR-

PIN_HX_DT  = 10
PIN_HX_SCK = 11

PIN_TOP    = 16   # top limit switch    (NC, PULL_UP; 1 when triggered)
PIN_BOT    = 17   # bottom limit switch (NC, PULL_UP; 1 when triggered)

# ---------------------------------------------------------------------------
# Mechanical constants
# ---------------------------------------------------------------------------
LEADSCREW_PITCH_MM  = 5.0
MOTOR_STEPS_PER_REV = 200
MICROSTEPS          = 8          # VERIFY against TB6600 DIP switches
STEPS_PER_MM = int(MOTOR_STEPS_PER_REV * MICROSTEPS / LEADSCREW_PITCH_MM)   # 320

DIR_UP   = 1                     # flip if wiring drives the stage the wrong way
DIR_DOWN = 0

# ---------------------------------------------------------------------------
# Follow-me tuning
#   Speeds in mm/s. Force thresholds in raw HX711 counts (tared).
#   Tune DEADBAND / FULLSPEED for your load cell by watching the status print.
# ---------------------------------------------------------------------------
FORCE_SIGN       = +1            # flip if pushing down moves the stage up

FORCE_DEADBAND   = 20000            # stepper is stopped while |reading| < this
FORCE_FULLSPEED  = 100000          # reading at/above this maps to MAX_SPEED_MMPS

MIN_SPEED_MMPS   = 0.3           # slowest meaningful follow speed
MAX_SPEED_MMPS   = 5.0           # fastest follow speed

STATUS_PERIOD_MS = 200
RAIL_GUARD       = 100           # reject HX711 rail-pinned glitches (±8388607)
FILTER_ALPHA     = 0.20          # EWMA low-pass: 0.0 = frozen, 1.0 = no smoothing
LOG_FILE         = 'follow_me_log.csv'

# ---------------------------------------------------------------------------
# Hardware init
# ---------------------------------------------------------------------------
lim_top  = Pin(PIN_TOP,  Pin.IN, pull=Pin.PULL_UP)
lim_bot  = Pin(PIN_BOT,  Pin.IN, pull=Pin.PULL_UP)

step_pin = Pin(PIN_STEP, Pin.OUT, value=0)
dir_pin  = Pin(PIN_DIR,  Pin.OUT, value=DIR_UP)

pin_sck  = Pin(PIN_HX_SCK, Pin.OUT)
pin_dt   = Pin(PIN_HX_DT,  Pin.IN, pull=Pin.PULL_DOWN)
hx = HX711(pin_sck, pin_dt, gain=128, state_machine=0)

# ---------------------------------------------------------------------------
# HX711 startup and tare
# ---------------------------------------------------------------------------
hx.power_down()
time.sleep_ms(100)
hx.power_up()
time.sleep_ms(500)

print("Taring load cell (keep it unloaded)...")
hx.tare(times=15)
raw_tare = hx.read()
print("Tare done.")

# ---------------------------------------------------------------------------
# Timer-driven stepper pulses. Callback toggles STEP; Timer freq is 2x step rate.
# ---------------------------------------------------------------------------
step_tmr = Timer()
_step_state = 0

def _step_cb(_t):
    global _step_state
    _step_state ^= 1
    step_pin.value(_step_state)

def start_stepper(mmps):
    freq_hz = int(2 * mmps * STEPS_PER_MM)
    step_tmr.init(freq=freq_hz, mode=Timer.PERIODIC, callback=_step_cb)

def stop_stepper():
    global _step_state
    try:
        step_tmr.deinit()
    except Exception:
        pass
    _step_state = 0
    step_pin.value(0)

# ---------------------------------------------------------------------------
# CSV
# ---------------------------------------------------------------------------
log_f = open(LOG_FILE, 'w')
log_f.write('time_ms,reading\n')
log_f.flush()
print(f"Logging to {LOG_FILE}")

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
def force_to_speed(mag):
    if mag <= FORCE_DEADBAND:
        return None
    if mag >= FORCE_FULLSPEED:
        return MAX_SPEED_MMPS
    ratio = (mag - FORCE_DEADBAND) / (FORCE_FULLSPEED - FORCE_DEADBAND)
    return MIN_SPEED_MMPS + ratio * (MAX_SPEED_MMPS - MIN_SPEED_MMPS)

_f_filtered = 0.0

def read_force():
    # Blocks ~100 ms per sample. Rejects rail-pins, then applies EWMA low-pass.
    # Returns raw tared HX711 counts (no unit conversion).
    global _f_filtered
    while True:
        val = hx.read()
        if val >=  8388607 - RAIL_GUARD:  continue
        if val <= -8388608 + RAIL_GUARD:  continue
        f_raw = FORCE_SIGN * (val - raw_tare)
        _f_filtered = FILTER_ALPHA * f_raw + (1.0 - FILTER_ALPHA) * _f_filtered
        return _f_filtered

# ---------------------------------------------------------------------------
# Main follow-me loop
# ---------------------------------------------------------------------------
t0 = time.ticks_ms()
print("Follow-me running. Push the load cell to move the stage. Ctrl+C to stop.\n")

cur_dir     = None   # DIR_UP, DIR_DOWN, or None (stopped)
cur_speed   = None
last_status = time.ticks_ms()

try:
    while True:
        f = read_force()
        t = time.ticks_diff(time.ticks_ms(), t0)
        #log_f.write(f'{t},{f:.0f}\n')

        mag = f if f >= 0 else -f
        want_dir = DIR_DOWN if f > 0 else DIR_UP

        blocked = (
            (want_dir == DIR_UP   and lim_top.value() == 1) or
            (want_dir == DIR_DOWN and lim_bot.value() == 1)
        )

        speed = None if blocked else force_to_speed(mag)

        if speed is None:
            if cur_speed is not None:
                stop_stepper()
                cur_dir   = None
                cur_speed = None
        else:
            if want_dir != cur_dir:
                stop_stepper()
                dir_pin.value(want_dir); time.sleep_us(5)
                start_stepper(speed)
                cur_dir   = want_dir
                cur_speed = speed
            elif speed != cur_speed:
                # Same direction, new target speed — re-init the Timer.
                start_stepper(speed)
                cur_speed = speed

        now = time.ticks_ms()
        if time.ticks_diff(now, last_status) >= STATUS_PERIOD_MS:
            last_status = now
            dir_str = "--" if cur_dir is None else ("UP" if cur_dir == DIR_UP else "DN")
            s_str   = "----" if cur_speed is None else f"{cur_speed:4.1f}"
            t_hit   = "T" if lim_top.value() == 1 else "."
            b_hit   = "B" if lim_bot.value() == 1 else "."
            print(f"reading={f:+8.0f}  dir={dir_str}  speed={s_str} mm/s  limits=[{t_hit}{b_hit}]")
            log_f.flush()

except KeyboardInterrupt:
    stop_stepper()
    log_f.flush()
    log_f.close()
    hx.power_down()
    print(f"\nStopped. Log: {LOG_FILE}")
